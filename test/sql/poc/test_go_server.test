require httpfs

require rpc

require tpch

# hardcoded the worker address
# orchestrate sends an http request

# table loaded on RPC extension side:

# CREATE TABLE tbl (
#     val INTEGER
# );
# INSERT INTO tbl (val) VALUES (1), (2);
# SELECT * FROM tbl;

query I
FROM orchestrate("client_id", "SELECT * FROM tbl", "http://localhost:8080/worker");
